# 环境公共配置（可复制为 .env；便携包 / CI 打包会用到）

# 应用名称
APP_NAME=ServerExchange

# 生产环境域名
DOMAIN=http://localhost:8080
# 开发环境域名
DOMAIN_DEV=http://localhost:3500

# 版本号
VERSION=1.0.0

# 接口统一前缀
API_PREFIX=/api

# JWT
JWT_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=7d
JWT_SECRET=change-me-before-production-use-at-least-32-chars

RESPONSE_INTERCEPTOR=false

THROTTLE_GLOBAL=false
THROTTLE_TTL=60000
THROTTLE_LIMIT=120

SWAGGER_ENABLED=false

DB_ENTITY_PREFIX=
DB_DATE_STRINGS=true
DB_SYNCHRONIZE=false
DB_LOGGING=false
DB_LOGGING_TYPE=file
DB_LOGGING_TYPE_DEV=file
