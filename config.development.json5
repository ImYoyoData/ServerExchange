//  容器访问宿主机
//  windows 可以用 host.docker.internal
//  linux 可以用 172.17.0.1
//  如果 linux 也想用 host.docker.internal  你可以设置网络映射网关实现
{
  httpPort: 3500, // http监听端口
  // AI Agent（TypeORM 实体生成、对话等）
  // provider: openai（Chat Completions）| anthropic（Messages API）
  // jinaKey 可选：用于 searchWeb / fetchWebPage 提升网络检索配额
  // 真实密钥请写在 config.development.local.json5（优先级更高）
  agent: {
    provider: 'openai',
    url: 'https://api.siliconflow.cn/v1',
    key: 'sk-xxxxxxxxxxx',
    model: 'deepseek-ai/DeepSeek-V3',
  },
  // 本地内存 + 文件缓存（替代 Redis；单机部署）
  cache: {
    open: true,
    memory: {
      ttlMs: 0,
      lruSize: 5000,
    },
    file: {
      filename: './.cache/kv.json',
      writeDelayMs: 100,
      expiredCheckDelayMs: 86400000,
    },
  },
  // 数据库配置
  database: {
    // 默认使用 SQLite，便于单机分发；结构/种子来自 sys.sql 导入
    default: {
      open: true,
      type: 'sqlite',
      database: './data/app.db',
      // 使用 sys.sql 导入的结构，避免 TypeORM synchronize 改表
      synchronize: false,
    },
    // MySQL（可选）
    mysql: {
      open: false,
      type: 'mysql',
      host: '127.0.0.1',
      port: 3306,
      username: 'yoyo',
      password: '123456',
      database: 'test',
      pool: {
        max: 30,
        min: 3,
        idleTimeoutMillis: 60000,
        connectionTimeoutMillis: 5000,
      },
    },
    pg1: {
      open: false,
      type: 'postgres',
      host: '127.0.0.1',
      port: 5432,
      username: 'yoyo',
      password: '123456',
      database: 'test',
    },
  },
}
