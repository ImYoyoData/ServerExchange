{
  httpPort: 3500, // http????
  // AI Agent?TypeORM ?????????
  // provider: openai?Chat Completions?| anthropic?Messages API?
  // jinaKey ????? searchWeb / fetchWebPage ????????
  // ??????? config.development.local.json5???????
  agent: {
    provider: 'openai',
    url: 'https://api.siliconflow.cn/v1',
    key: 'sk-xxxxxxxxxxx',
    model: 'deepseek-ai/DeepSeek-V3',
  },
  // ???? + ??????? Redis??????
  cache: {
    open: true,
    memory: {
      ttlMs: 0,
      lruSize: 5000,
    },
    file: {
      filename: './.cache/kv.json',
      writeDelayMs: 100,
      expiredCheckDelayMs: 86400000,
    },
  },
  // ?????
  database: {
    // ???? SQLite??????????/???? sys.sql ??
    default: {
      open: true,
      type: 'sqlite',
      database: './data/app.db',
      // ???TypeORM synchronize ???????????????????? sys.sql
      synchronize: true,
    },
    // MySQL????
    mysql: {
      open: false,
      type: 'mysql',
      host: '127.0.0.1',
      port: 3306,
      username: 'yoyo',
      password: '123456',
      database: 'test',
      pool: {
        max: 30,
        min: 3,
        idleTimeoutMillis: 60000,
        connectionTimeoutMillis: 5000,
      },
    },
    pg1: {
      open: false,
      type: 'postgres',
      host: '127.0.0.1',
      port: 5432,
      username: 'yoyo',
      password: '123456',
      database: 'test',
    },
  },
}
